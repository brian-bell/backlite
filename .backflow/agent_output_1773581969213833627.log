{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V2CuA72cJgokdvYFpTZQZZ","type":"tool_result","content":"     1→package notify\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/rs/zerolog/log\"\n    11→)\n    12→\n    13→type EventType string\n    14→\n    15→const (\n    16→\tEventTaskCreated     EventType = \"task.created\"\n    17→\tEventTaskRunning     EventType = \"task.running\"\n    18→\tEventTaskCompleted   EventType = \"task.completed\"\n    19→\tEventTaskFailed      EventType = \"task.failed\"\n    20→\tEventTaskNeedsInput  EventType = \"task.needs_input\"\n    21→\tEventTaskInterrupted EventType = \"task.interrupted\"\n    22→)\n    23→\n    24→type Event struct {\n    25→\tType           EventType `json:\"event\"`\n    26→\tTaskID         string    `json:\"task_id\"`\n    27→\tRepoURL        string    `json:\"repo_url,omitempty\"`\n    28→\tPrompt         string    `json:\"prompt,omitempty\"`\n    29→\tMessage        string    `json:\"message,omitempty\"`\n    30→\tPRURL          string    `json:\"pr_url,omitempty\"`\n    31→\tAgentLogTail   string    `json:\"agent_log_tail,omitempty\"`\n    32→\tTimestamp      time.Time `json:\"timestamp\"`\n    33→}\n    34→\n    35→// Notifier sends notifications for task lifecycle events.\n    36→type Notifier interface {\n    37→\tNotify(event Event) error\n    38→}\n    39→\n    40→// NoopNotifier discards all events.\n    41→type NoopNotifier struct{}\n    42→\n    43→func (NoopNotifier) Notify(Event) error { return nil }\n    44→\n    45→// WebhookNotifier sends HTTP POST notifications.\n    46→type WebhookNotifier struct {\n    47→\turl        string\n    48→\tevents     map[EventType]bool // nil = all events\n    49→\thttpClient *http.Client\n    50→}\n    51→\n    52→func NewWebhookNotifier(url string, filterEvents []string) *WebhookNotifier {\n    53→\tw := &WebhookNotifier{\n    54→\t\turl: url,\n    55→\t\thttpClient: &http.Client{\n    56→\t\t\tTimeout: 10 * time.Second,\n    57→\t\t},\n    58→\t}\n    59→\tif len(filterEvents) > 0 {\n    60→\t\tw.events = make(map[EventType]bool, len(filterEvents))\n    61→\t\tfor _, e := range filterEvents {\n    62→\t\t\tw.events[EventType(e)] = true\n    63→\t\t}\n    64→\t}\n    65→\treturn w\n    66→}\n    67→\n    68→func (w *WebhookNotifier) Notify(event Event) error {\n    69→\tif w.events != nil && !w.events[event.Type] {\n    70→\t\treturn nil\n    71→\t}\n    72→\n    73→\tbody, err := json.Marshal(event)\n    74→\tif err != nil {\n    75→\t\treturn fmt.Errorf(\"marshal event: %w\", err)\n    76→\t}\n    77→\n    78→\tvar lastErr error\n    79→\tfor attempt := 0; attempt < 3; attempt++ {\n    80→\t\tif attempt > 0 {\n    81→\t\t\ttime.Sleep(time.Duration(attempt) * 2 * time.Second)\n    82→\t\t}\n    83→\n    84→\t\treq, err := http.NewRequest(http.MethodPost, w.url, bytes.NewReader(body))\n    85→\t\tif err != nil {\n    86→\t\t\treturn fmt.Errorf(\"create request: %w\", err)\n    87→\t\t}\n    88→\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n    89→\t\treq.Header.Set(\"User-Agent\", \"backflow-webhook/1.0\")\n    90→\n    91→\t\tresp, err := w.httpClient.Do(req)\n    92→\t\tif err != nil {\n    93→\t\t\tlastErr = err\n    94→\t\t\tlog.Warn().Err(err).Int(\"attempt\", attempt+1).Str(\"event\", string(event.Type)).Msg(\"webhook request failed\")\n    95→\t\t\tcontinue\n    96→\t\t}\n    97→\t\tresp.Body.Close()\n    98→\n    99→\t\tif resp.StatusCode >= 200 && resp.StatusCode < 300 {\n   100→\t\t\tlog.Debug().Str(\"event\", string(event.Type)).Str(\"task_id\", event.TaskID).Msg(\"webhook sent\")\n   101→\t\t\treturn nil\n   102→\t\t}\n   103→\t\tlastErr = fmt.Errorf(\"webhook returned status %d\", resp.StatusCode)\n   104→\t\tlog.Warn().Int(\"status\", resp.StatusCode).Int(\"attempt\", attempt+1).Msg(\"webhook non-2xx response\")\n   105→\t}\n   106→\n   107→\treturn fmt.Errorf(\"webhook failed after 3 attempts: %w\", lastErr)\n   108→}\n   109→"}]},"parent_tool_use_id":null,"session_id":"4aa0ce57-5476-4987-a635-a74810c9f869","uuid":"b75e7859-eb83-4264-a156-ac544b92ae11","tool_use_result":{"type":"text","file":{"filePath":"/home/agent/workspace/internal/notify/webhook.go","content":"package notify\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"time\"\n\n\t\"github.com/rs/zerolog/log\"\n)\n\ntype EventType string\n\nconst (\n\tEventTaskCreated     EventType = \"task.created\"\n\tEventTaskRunning     EventType = \"task.running\"\n\tEventTaskCompleted   EventType = \"task.completed\"\n\tEventTaskFailed      EventType = \"task.failed\"\n\tEventTaskNeedsInput  EventType = \"task.needs_input\"\n\tEventTaskInterrupted EventType = \"task.interrupted\"\n)\n\ntype Event struct {\n\tType           EventType `json:\"event\"`\n\tTaskID         string    `json:\"task_id\"`\n\tRepoURL        string    `json:\"repo_url,omitempty\"`\n\tPrompt         string    `json:\"prompt,omitempty\"`\n\tMessage        string    `json:\"message,omitempty\"`\n\tPRURL          string    `json:\"pr_url,omitempty\"`\n\tAgentLogTail   string    `json:\"agent_log_tail,omitempty\"`\n\tTimestamp      time.Time `json:\"timestamp\"`\n}\n\n// Notifier sends notifications for task lifecycle events.\ntype Notifier interface {\n\tNotify(event Event) error\n}\n\n// NoopNotifier discards all events.\ntype NoopNotifier struct{}\n\nfunc (NoopNotifier) Notify(Event) error { return nil }\n\n// WebhookNotifier sends HTTP POST notifications.\ntype WebhookNotifier struct {\n\turl        string\n\tevents     map[EventType]bool // nil = all events\n\thttpClient *http.Client\n}\n\nfunc NewWebhookNotifier(url string, filterEvents []string) *WebhookNotifier {\n\tw := &WebhookNotifier{\n\t\turl: url,\n\t\thttpClient: &http.Client{\n\t\t\tTimeout: 10 * time.Second,\n\t\t},\n\t}\n\tif len(filterEvents) > 0 {\n\t\tw.events = make(map[EventType]bool, len(filterEvents))\n\t\tfor _, e := range filterEvents {\n\t\t\tw.events[EventType(e)] = true\n\t\t}\n\t}\n\treturn w\n}\n\nfunc (w *WebhookNotifier) Notify(event Event) error {\n\tif w.events != nil && !w.events[event.Type] {\n\t\treturn nil\n\t}\n\n\tbody, err := json.Marshal(event)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"marshal event: %w\", err)\n\t}\n\n\tvar lastErr error\n\tfor attempt := 0; attempt < 3; attempt++ {\n\t\tif attempt > 0 {\n\t\t\ttime.Sleep(time.Duration(attempt) * 2 * time.Second)\n\t\t}\n\n\t\treq, err := http.NewRequest(http.MethodPost, w.url, bytes.NewReader(body))\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"create request: %w\", err)\n\t\t}\n\t\treq.Header.Set(\"Content-Type\", \"application/json\")\n\t\treq.Header.Set(\"User-Agent\", \"backflow-webhook/1.0\")\n\n\t\tresp, err := w.httpClient.Do(req)\n\t\tif err != nil {\n\t\t\tlastErr = err\n\t\t\tlog.Warn().Err(err).Int(\"attempt\", attempt+1).Str(\"event\", string(event.Type)).Msg(\"webhook request failed\")\n\t\t\tcontinue\n\t\t}\n\t\tresp.Body.Close()\n\n\t\tif resp.StatusCode >= 200 && resp.StatusCode < 300 {\n\t\t\tlog.Debug().Str(\"event\", string(event.Type)).Str(\"task_id\", event.TaskID).Msg(\"webhook sent\")\n\t\t\treturn nil\n\t\t}\n\t\tlastErr = fmt.Errorf(\"webhook returned status %d\", resp.StatusCode)\n\t\tlog.Warn().Int(\"status\", resp.StatusCode).Int(\"attempt\", attempt+1).Msg(\"webhook non-2xx response\")\n\t}\n\n\treturn fmt.Errorf(\"webhook failed after 3 attempts: %w\", lastErr)\n}\n","numLines":109,"startLine":1,"totalLines":109}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DM7eumAcTrctMUFDnXi5WK","type":"tool_result","content":"     1→package api\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"net/http\"\n     7→\t\"strconv\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/go-chi/chi/v5\"\n    11→\t\"github.com/oklog/ulid/v2\"\n    12→\n    13→\t\"github.com/backflow-labs/backflow/internal/config\"\n    14→\t\"github.com/backflow-labs/backflow/internal/models\"\n    15→\t\"github.com/backflow-labs/backflow/internal/store\"\n    16→)\n    17→\n    18→// LogFetcher retrieves container logs for a running task.\n    19→type LogFetcher interface {\n    20→\tGetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error)\n    21→}\n    22→\n    23→type Handlers struct {\n    24→\tstore  store.Store\n    25→\tconfig *config.Config\n    26→\tlogs   LogFetcher\n    27→}\n    28→\n    29→func NewHandlers(s store.Store, cfg *config.Config, logs LogFetcher) *Handlers {\n    30→\treturn &Handlers{store: s, config: cfg, logs: logs}\n    31→}\n    32→\n    33→func (h *Handlers) CreateTask(w http.ResponseWriter, r *http.Request) {\n    34→\tvar req models.CreateTaskRequest\n    35→\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n    36→\t\twriteError(w, http.StatusBadRequest, \"invalid JSON: \"+err.Error())\n    37→\t\treturn\n    38→\t}\n    39→\tif err := req.Validate(); err != nil {\n    40→\t\twriteError(w, http.StatusBadRequest, err.Error())\n    41→\t\treturn\n    42→\t}\n    43→\n    44→\tnow := time.Now().UTC()\n    45→\ttask := &models.Task{\n    46→\t\tID:            \"bf_\" + ulid.Make().String(),\n    47→\t\tStatus:        models.TaskStatusPending,\n    48→\t\tRepoURL:       req.RepoURL,\n    49→\t\tBranch:        req.Branch,\n    50→\t\tTargetBranch:  req.TargetBranch,\n    51→\t\tPrompt:        req.Prompt,\n    52→\t\tContext:       req.Context,\n    53→\t\tModel:         withDefault(req.Model, h.config.DefaultModel),\n    54→\t\tEffort:        withDefault(req.Effort, h.config.DefaultEffort),\n    55→\t\tMaxBudgetUSD:  withDefaultFloat(req.MaxBudgetUSD, h.config.DefaultMaxBudget),\n    56→\t\tMaxRuntimeMin: withDefaultInt(req.MaxRuntimeMin, int(h.config.DefaultMaxRuntime.Minutes())),\n    57→\t\tMaxTurns:      withDefaultInt(req.MaxTurns, h.config.DefaultMaxTurns),\n    58→\t\tCreatePR:      req.CreatePR,\n    59→\t\tSelfReview:    req.SelfReview,\n    60→\t\tPRTitle:       req.PRTitle,\n    61→\t\tPRBody:        req.PRBody,\n    62→\t\tAllowedTools:  req.AllowedTools,\n    63→\t\tClaudeMD:      req.ClaudeMD,\n    64→\t\tEnvVars:       req.EnvVars,\n    65→\t\tCreatedAt:     now,\n    66→\t\tUpdatedAt:     now,\n    67→\t}\n    68→\n    69→\tif err := h.store.CreateTask(r.Context(), task); err != nil {\n    70→\t\twriteError(w, http.StatusInternalServerError, \"failed to create task\")\n    71→\t\treturn\n    72→\t}\n    73→\n    74→\twriteJSON(w, http.StatusCreated, task)\n    75→}\n    76→\n    77→func (h *Handlers) GetTask(w http.ResponseWriter, r *http.Request) {\n    78→\tid := chi.URLParam(r, \"id\")\n    79→\ttask, err := h.store.GetTask(r.Context(), id)\n    80→\tif err != nil {\n    81→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n    82→\t\treturn\n    83→\t}\n    84→\tif task == nil {\n    85→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n    86→\t\treturn\n    87→\t}\n    88→\twriteJSON(w, http.StatusOK, task)\n    89→}\n    90→\n    91→func (h *Handlers) ListTasks(w http.ResponseWriter, r *http.Request) {\n    92→\tfilter := store.TaskFilter{\n    93→\t\tLimit:  50,\n    94→\t\tOffset: 0,\n    95→\t}\n    96→\tif s := r.URL.Query().Get(\"status\"); s != \"\" {\n    97→\t\tstatus := models.TaskStatus(s)\n    98→\t\tfilter.Status = &status\n    99→\t}\n   100→\tif l := r.URL.Query().Get(\"limit\"); l != \"\" {\n   101→\t\tif n, err := strconv.Atoi(l); err == nil && n > 0 {\n   102→\t\t\tfilter.Limit = n\n   103→\t\t}\n   104→\t}\n   105→\tif o := r.URL.Query().Get(\"offset\"); o != \"\" {\n   106→\t\tif n, err := strconv.Atoi(o); err == nil && n >= 0 {\n   107→\t\t\tfilter.Offset = n\n   108→\t\t}\n   109→\t}\n   110→\n   111→\ttasks, err := h.store.ListTasks(r.Context(), filter)\n   112→\tif err != nil {\n   113→\t\twriteError(w, http.StatusInternalServerError, \"failed to list tasks\")\n   114→\t\treturn\n   115→\t}\n   116→\tif tasks == nil {\n   117→\t\ttasks = []*models.Task{}\n   118→\t}\n   119→\twriteJSON(w, http.StatusOK, tasks)\n   120→}\n   121→\n   122→func (h *Handlers) DeleteTask(w http.ResponseWriter, r *http.Request) {\n   123→\tid := chi.URLParam(r, \"id\")\n   124→\ttask, err := h.store.GetTask(r.Context(), id)\n   125→\tif err != nil {\n   126→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   127→\t\treturn\n   128→\t}\n   129→\tif task == nil {\n   130→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   131→\t\treturn\n   132→\t}\n   133→\n   134→\t// If running, mark as cancelled (orchestrator will kill the container)\n   135→\tif task.Status == models.TaskStatusRunning || task.Status == models.TaskStatusProvisioning {\n   136→\t\ttask.Status = models.TaskStatusCancelled\n   137→\t\tnow := time.Now().UTC()\n   138→\t\ttask.CompletedAt = &now\n   139→\t\tif err := h.store.UpdateTask(r.Context(), task); err != nil {\n   140→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to cancel task\")\n   141→\t\t\treturn\n   142→\t\t}\n   143→\t} else if !task.Status.IsTerminal() {\n   144→\t\tif err := h.store.DeleteTask(r.Context(), id); err != nil {\n   145→\t\t\twriteError(w, http.StatusInternalServerError, \"failed to delete task\")\n   146→\t\t\treturn\n   147→\t\t}\n   148→\t}\n   149→\n   150→\tw.WriteHeader(http.StatusNoContent)\n   151→}\n   152→\n   153→func (h *Handlers) GetTaskLogs(w http.ResponseWriter, r *http.Request) {\n   154→\tid := chi.URLParam(r, \"id\")\n   155→\ttask, err := h.store.GetTask(r.Context(), id)\n   156→\tif err != nil {\n   157→\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n   158→\t\treturn\n   159→\t}\n   160→\tif task == nil {\n   161→\t\twriteError(w, http.StatusNotFound, \"task not found\")\n   162→\t\treturn\n   163→\t}\n   164→\n   165→\tif task.InstanceID == \"\" || task.ContainerID == \"\" {\n   166→\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   167→\t\tw.WriteHeader(http.StatusOK)\n   168→\t\tmsg := \"status: \" + string(task.Status) + \"\\n\"\n   169→\t\tif task.Error != \"\" {\n   170→\t\t\tmsg += \"error: \" + task.Error + \"\\n\"\n   171→\t\t}\n   172→\t\tw.Write([]byte(msg))\n   173→\t\treturn\n   174→\t}\n   175→\n   176→\ttail := 100\n   177→\tif t := r.URL.Query().Get(\"tail\"); t != \"\" {\n   178→\t\tif n, err := strconv.Atoi(t); err == nil && n > 0 {\n   179→\t\t\ttail = n\n   180→\t\t}\n   181→\t}\n   182→\n   183→\tlogs, err := h.logs.GetLogs(r.Context(), task.InstanceID, task.ContainerID, tail)\n   184→\tif err != nil {\n   185→\t\twriteError(w, http.StatusBadGateway, \"failed to fetch logs: \"+err.Error())\n   186→\t\treturn\n   187→\t}\n   188→\n   189→\tw.Header().Set(\"Content-Type\", \"text/plain\")\n   190→\tw.WriteHeader(http.StatusOK)\n   191→\tw.Write([]byte(logs))\n   192→}\n   193→\n   194→func (h *Handlers) HealthCheck(w http.ResponseWriter, r *http.Request) {\n   195→\twriteJSON(w, http.StatusOK, map[string]string{\n   196→\t\t\"status\":    \"ok\",\n   197→\t\t\"auth_mode\": string(h.config.AuthMode),\n   198→\t})\n   199→}\n   200→\n   201→func withDefault(val, fallback string) string {\n   202→\tif val == \"\" {\n   203→\t\treturn fallback\n   204→\t}\n   205→\treturn val\n   206→}\n   207→\n   208→func withDefaultFloat(val, fallback float64) float64 {\n   209→\tif val == 0 {\n   210→\t\treturn fallback\n   211→\t}\n   212→\treturn val\n   213→}\n   214→\n   215→func withDefaultInt(val, fallback int) int {\n   216→\tif val == 0 {\n   217→\t\treturn fallback\n   218→\t}\n   219→\treturn val\n   220→}\n   221→"}]},"parent_tool_use_id":null,"session_id":"4aa0ce57-5476-4987-a635-a74810c9f869","uuid":"18a4ecc3-e5c8-4e89-a530-2c95141cc903","tool_use_result":{"type":"text","file":{"filePath":"/home/agent/workspace/internal/api/handlers.go","content":"package api\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"net/http\"\n\t\"strconv\"\n\t\"time\"\n\n\t\"github.com/go-chi/chi/v5\"\n\t\"github.com/oklog/ulid/v2\"\n\n\t\"github.com/backflow-labs/backflow/internal/config\"\n\t\"github.com/backflow-labs/backflow/internal/models\"\n\t\"github.com/backflow-labs/backflow/internal/store\"\n)\n\n// LogFetcher retrieves container logs for a running task.\ntype LogFetcher interface {\n\tGetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error)\n}\n\ntype Handlers struct {\n\tstore  store.Store\n\tconfig *config.Config\n\tlogs   LogFetcher\n}\n\nfunc NewHandlers(s store.Store, cfg *config.Config, logs LogFetcher) *Handlers {\n\treturn &Handlers{store: s, config: cfg, logs: logs}\n}\n\nfunc (h *Handlers) CreateTask(w http.ResponseWriter, r *http.Request) {\n\tvar req models.CreateTaskRequest\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\twriteError(w, http.StatusBadRequest, \"invalid JSON: \"+err.Error())\n\t\treturn\n\t}\n\tif err := req.Validate(); err != nil {\n\t\twriteError(w, http.StatusBadRequest, err.Error())\n\t\treturn\n\t}\n\n\tnow := time.Now().UTC()\n\ttask := &models.Task{\n\t\tID:            \"bf_\" + ulid.Make().String(),\n\t\tStatus:        models.TaskStatusPending,\n\t\tRepoURL:       req.RepoURL,\n\t\tBranch:        req.Branch,\n\t\tTargetBranch:  req.TargetBranch,\n\t\tPrompt:        req.Prompt,\n\t\tContext:       req.Context,\n\t\tModel:         withDefault(req.Model, h.config.DefaultModel),\n\t\tEffort:        withDefault(req.Effort, h.config.DefaultEffort),\n\t\tMaxBudgetUSD:  withDefaultFloat(req.MaxBudgetUSD, h.config.DefaultMaxBudget),\n\t\tMaxRuntimeMin: withDefaultInt(req.MaxRuntimeMin, int(h.config.DefaultMaxRuntime.Minutes())),\n\t\tMaxTurns:      withDefaultInt(req.MaxTurns, h.config.DefaultMaxTurns),\n\t\tCreatePR:      req.CreatePR,\n\t\tSelfReview:    req.SelfReview,\n\t\tPRTitle:       req.PRTitle,\n\t\tPRBody:        req.PRBody,\n\t\tAllowedTools:  req.AllowedTools,\n\t\tClaudeMD:      req.ClaudeMD,\n\t\tEnvVars:       req.EnvVars,\n\t\tCreatedAt:     now,\n\t\tUpdatedAt:     now,\n\t}\n\n\tif err := h.store.CreateTask(r.Context(), task); err != nil {\n\t\twriteError(w, http.StatusInternalServerError, \"failed to create task\")\n\t\treturn\n\t}\n\n\twriteJSON(w, http.StatusCreated, task)\n}\n\nfunc (h *Handlers) GetTask(w http.ResponseWriter, r *http.Request) {\n\tid := chi.URLParam(r, \"id\")\n\ttask, err := h.store.GetTask(r.Context(), id)\n\tif err != nil {\n\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n\t\treturn\n\t}\n\tif task == nil {\n\t\twriteError(w, http.StatusNotFound, \"task not found\")\n\t\treturn\n\t}\n\twriteJSON(w, http.StatusOK, task)\n}\n\nfunc (h *Handlers) ListTasks(w http.ResponseWriter, r *http.Request) {\n\tfilter := store.TaskFilter{\n\t\tLimit:  50,\n\t\tOffset: 0,\n\t}\n\tif s := r.URL.Query().Get(\"status\"); s != \"\" {\n\t\tstatus := models.TaskStatus(s)\n\t\tfilter.Status = &status\n\t}\n\tif l := r.URL.Query().Get(\"limit\"); l != \"\" {\n\t\tif n, err := strconv.Atoi(l); err == nil && n > 0 {\n\t\t\tfilter.Limit = n\n\t\t}\n\t}\n\tif o := r.URL.Query().Get(\"offset\"); o != \"\" {\n\t\tif n, err := strconv.Atoi(o); err == nil && n >= 0 {\n\t\t\tfilter.Offset = n\n\t\t}\n\t}\n\n\ttasks, err := h.store.ListTasks(r.Context(), filter)\n\tif err != nil {\n\t\twriteError(w, http.StatusInternalServerError, \"failed to list tasks\")\n\t\treturn\n\t}\n\tif tasks == nil {\n\t\ttasks = []*models.Task{}\n\t}\n\twriteJSON(w, http.StatusOK, tasks)\n}\n\nfunc (h *Handlers) DeleteTask(w http.ResponseWriter, r *http.Request) {\n\tid := chi.URLParam(r, \"id\")\n\ttask, err := h.store.GetTask(r.Context(), id)\n\tif err != nil {\n\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n\t\treturn\n\t}\n\tif task == nil {\n\t\twriteError(w, http.StatusNotFound, \"task not found\")\n\t\treturn\n\t}\n\n\t// If running, mark as cancelled (orchestrator will kill the container)\n\tif task.Status == models.TaskStatusRunning || task.Status == models.TaskStatusProvisioning {\n\t\ttask.Status = models.TaskStatusCancelled\n\t\tnow := time.Now().UTC()\n\t\ttask.CompletedAt = &now\n\t\tif err := h.store.UpdateTask(r.Context(), task); err != nil {\n\t\t\twriteError(w, http.StatusInternalServerError, \"failed to cancel task\")\n\t\t\treturn\n\t\t}\n\t} else if !task.Status.IsTerminal() {\n\t\tif err := h.store.DeleteTask(r.Context(), id); err != nil {\n\t\t\twriteError(w, http.StatusInternalServerError, \"failed to delete task\")\n\t\t\treturn\n\t\t}\n\t}\n\n\tw.WriteHeader(http.StatusNoContent)\n}\n\nfunc (h *Handlers) GetTaskLogs(w http.ResponseWriter, r *http.Request) {\n\tid := chi.URLParam(r, \"id\")\n\ttask, err := h.store.GetTask(r.Context(), id)\n\tif err != nil {\n\t\twriteError(w, http.StatusInternalServerError, \"failed to get task\")\n\t\treturn\n\t}\n\tif task == nil {\n\t\twriteError(w, http.StatusNotFound, \"task not found\")\n\t\treturn\n\t}\n\n\tif task.InstanceID == \"\" || task.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n\t\tw.WriteHeader(http.StatusOK)\n\t\tmsg := \"status: \" + string(task.Status) + \"\\n\"\n\t\tif task.Error != \"\" {\n\t\t\tmsg += \"error: \" + task.Error + \"\\n\"\n\t\t}\n\t\tw.Write([]byte(msg))\n\t\treturn\n\t}\n\n\ttail := 100\n\tif t := r.URL.Query().Get(\"tail\"); t != \"\" {\n\t\tif n, err := strconv.Atoi(t); err == nil && n > 0 {\n\t\t\ttail = n\n\t\t}\n\t}\n\n\tlogs, err := h.logs.GetLogs(r.Context(), task.InstanceID, task.ContainerID, tail)\n\tif err != nil {\n\t\twriteError(w, http.StatusBadGateway, \"failed to fetch logs: \"+err.Error())\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/plain\")\n\tw.WriteHeader(http.StatusOK)\n\tw.Write([]byte(logs))\n}\n\nfunc (h *Handlers) HealthCheck(w http.ResponseWriter, r *http.Request) {\n\twriteJSON(w, http.StatusOK, map[string]string{\n\t\t\"status\":    \"ok\",\n\t\t\"auth_mode\": string(h.config.AuthMode),\n\t})\n}\n\nfunc withDefault(val, fallback string) string {\n\tif val == \"\" {\n\t\treturn fallback\n\t}\n\treturn val\n}\n\nfunc withDefaultFloat(val, fallback float64) float64 {\n\tif val == 0 {\n\t\treturn fallback\n\t}\n\treturn val\n}\n\nfunc withDefaultInt(val, fallback int) int {\n\tif val == 0 {\n\t\treturn fallback\n\t}\n\treturn val\n}\n","numLines":221,"startLine":1,"totalLines":221}}}
