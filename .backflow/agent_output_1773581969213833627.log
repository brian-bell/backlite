iled: %s\", containerID)\n    54→\t}\n    55→\n    56→\tlog.Debug().Str(\"container\", containerID[:12]).Str(\"instance\", instance.InstanceID).Msg(\"started agent container\")\n    57→\treturn containerID, nil\n    58→}\n    59→\n    60→// InspectContainer checks a container's status and reads the agent's\n    61→// status.json if the container has exited.\n    62→func (m *DockerManager) InspectContainer(ctx context.Context, instanceID, containerID string) (ContainerStatus, error) {\n    63→\tcmd := fmt.Sprintf(\n    64→\t\t\"docker inspect --format '{{.State.Status}} {{.State.ExitCode}}' %s 2>/dev/null && docker logs --tail 20 %s 2>&1\",\n    65→\t\tcontainerID, containerID,\n    66→\t)\n    67→\toutput, err := m.runCommand(ctx, instanceID, cmd)\n    68→\tif err != nil {\n    69→\t\treturn ContainerStatus{}, err\n    70→\t}\n    71→\n    72→\tstatus, err := parseInspectOutput(output)\n    73→\tif err != nil {\n    74→\t\treturn ContainerStatus{}, err\n    75→\t}\n    76→\n    77→\tif status.Done {\n    78→\t\tm.enrichFromStatusJSON(ctx, instanceID, containerID, &status)\n    79→\t}\n    80→\n    81→\treturn status, nil\n    82→}\n    83→\n    84→// StopContainer stops and removes a container.\n    85→func (m *DockerManager) StopContainer(ctx context.Context, instanceID, containerID string) error {\n    86→\tcmd := fmt.Sprintf(\"docker stop -t 30 %s 2>/dev/null; docker rm %s 2>/dev/null\", containerID, containerID)\n    87→\t_, err := m.runCommand(ctx, instanceID, cmd)\n    88→\treturn err\n    89→}\n    90→\n    91→// GetLogs retrieves the last N lines of a container's logs.\n    92→func (m *DockerManager) GetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error) {\n    93→\tcmd := fmt.Sprintf(\"docker logs --tail %d %s 2>&1\", tail, containerID)\n    94→\treturn m.runCommand(ctx, instanceID, cmd)\n    95→}\n    96→\n    97→// buildRunCommand constructs the full `docker run` command for an agent task.\n    98→func (m *DockerManager) buildRunCommand(task *models.Task) string {\n    99→\tenvFlags := m.buildEnvFlags(task)\n   100→\tvolumeFlags := m.buildVolumeFlags()\n   101→\n   102→\treturn fmt.Sprintf(\n   103→\t\t\"docker run -d --cpus=1 --memory=3g %s %s backflow-agent\",\n   104→\t\tvolumeFlags,\n   105→\t\tstrings.Join(envFlags, \" \"),\n   106→\t)\n   107→}\n   108→\n   109→// buildEnvFlags assembles the -e flags for the docker run command from the\n   110→// task configuration and global config.\n   111→func (m *DockerManager) buildEnvFlags(task *models.Task) []string {\n   112→\tflags := []string{\n   113→\t\tenvFlag(\"TASK_ID\", task.ID),\n   114→\t\tenvFlag(\"REPO_URL\", shellEscape(task.RepoURL)),\n   115→\t\tenvFlag(\"BRANCH\", shellEscape(task.Branch)),\n   116→\t\tenvFlag(\"TARGET_BRANCH\", shellEscape(task.TargetBranch)),\n   117→\t\tenvFlag(\"PROMPT\", shellEscape(task.Prompt)),\n   118→\t\tenvFlag(\"MODEL\", shellEscape(task.Model)),\n   119→\t\tenvFlag(\"EFFORT\", shellEscape(task.Effort)),\n   120→\t\tfmt.Sprintf(\"-e MAX_BUDGET_USD=%g\", task.MaxBudgetUSD),\n   121→\t\tfmt.Sprintf(\"-e MAX_TURNS=%d\", task.MaxTurns),\n   122→\t\tfmt.Sprintf(\"-e CREATE_PR=%t\", task.CreatePR),\n   123→\t\tfmt.Sprintf(\"-e SELF_REVIEW=%t\", task.SelfReview),\n   124→\t\tenvFlag(\"AUTH_MODE\", string(m.config.AuthMode)),\n   125→\t}\n   126→\n   127→\t// Optional task fields\n   128→\tif task.PRTitle != \"\" {\n   129→\t\tflags = append(flags, envFlag(\"PR_TITLE\", shellEscape(task.PRTitle)))\n   130→\t}\n   131→\tif task.PRBody != \"\" {\n   132→\t\tflags = append(flags, envFlag(\"PR_BODY\", shellEscape(task.PRBody)))\n   133→\t}\n   134→\tif task.ClaudeMD != \"\" {\n   135→\t\tflags = append(flags, envFlag(\"CLAUDE_MD\", shellEscape(task.ClaudeMD)))\n   136→\t}\n   137→\tif task.Context != \"\" {\n   138→\t\tflags = append(flags, envFlag(\"TASK_CONTEXT\", shellEscape(task.Context)))\n   139→\t}\n   140→\n   141→\t// Auth credentials\n   142→\tif m.config.AuthMode == config.AuthModeAPIKey {\n   143→\t\tflags = append(flags, envFlag(\"ANTHROPIC_API_KEY\", m.config.AnthropicAPIKey))\n   144→\t}\n   145→\tif m.config.GitHubToken != \"\" {\n   146→\t\tflags = append(flags, envFlag(\"GITHUB_TOKEN\", m.config.GitHubToken))\n   147→\t}\n   148→\n   149→\t// Custom env vars from the task\n   150→\tfor k, v := range task.EnvVars {\n   151→\t\tflags = append(flags, envFlag(k, shellEscape(v)))\n   152→\t}\n   153→\n   154→\treturn flags\n   155→}\n   156→\n   157→// buildVolumeFlags returns the -v flag for mounting Claude credentials when\n   158→// using Max subscription auth, or an empty string otherwise.\n   159→func (m *DockerManager) buildVolumeFlags() string {\n   160→\tif m.config.AuthMode == config.AuthModeMaxSubscription && m.config.ClaudeCredentialsPath != \"\" {\n   161→\t\treturn fmt.Sprintf(\"-v %s:/home/agent/.claude:ro\", m.config.ClaudeCredentialsPath)\n   162→\t}\n   163→\treturn \"\"\n   164→}\n   165→\n   166→// envFlag returns a single \"-e KEY=VALUE\" flag string.\n   167→func envFlag(key, value string) string {\n   168→\treturn fmt.Sprintf(\"-e %s=%s\", key, value)\n   169→}\n   170→\n   171→// agentStatus is the JSON structure written by the agent entrypoint to\n   172→// /home/agent/workspace/status.json inside the container.\n   173→type agentStatus struct {\n   174→\tNeedsInput bool   `json:\"needs_input\"`\n   175→\tQuestion   string `json:\"question\"`\n   176→\tComplete   bool   `json:\"complete\"`\n   177→\tError      string `json:\"error\"`\n   178→\tPRURL      string `json:\"pr_url\"`\n   179→}\n   180→\n   181→// parseInspectOutput parses the combined output of `docker inspect` +\n   182→// `docker logs` into a ContainerStatus.\n   183→func parseInspectOutput(output string) (ContainerStatus, error) {\n   184→\tlines := strings.SplitN(output, \"\\n\", 2)\n   185→\tif len(lines) == 0 {\n   186→\t\treturn ContainerStatus{}, fmt.Errorf(\"empty inspect output\")\n   187→\t}\n   188→\n   189→\tparts := strings.Fields(lines[0])\n   190→\tif len(parts) < 2 {\n   191→\t\treturn ContainerStatus{}, fmt.Errorf(\"unexpected inspect format: %s\", lines[0])\n   192→\t}\n   193→\n   194→\tstatus := ContainerStatus{}\n   195→\tif len(lines) > 1 {\n   196→\t\tstatus.LogTail = lines[1]\n   197→\t}\n   198→\n   199→\tdockerState := parts[0]\n   200→\tif dockerState == \"exited\" || dockerState == \"dead\" {\n   201→\t\tstatus.Done = true\n   202→\t\tfmt.Sscanf(parts[1], \"%d\", &status.ExitCode)\n   203→\t\tif status.ExitCode != 0 {\n   204→\t\t\tstatus.Error = fmt.Sprintf(\"container exited with code %d\", status.ExitCode)\n   205→\t\t}\n   206→\t}\n   207→\n   208→\treturn status, nil\n   209→}\n   210→\n   211→// enrichFromStatusJSON reads the agent's status.json from the container and\n   212→// merges its fields into the ContainerStatus.\n   213→func (m *DockerManager) enrichFromStatusJSON(ctx context.Context, instanceID, containerID string, status *ContainerStatus) {\n   214→\tcmd := fmt.Sprintf(\"docker cp %s:/home/agent/workspace/status.json /dev/stdout 2>/dev/null\", containerID)\n   215→\tstatusJSON, err := m.runCommand(ctx, instanceID, cmd)\n   216→\tif err != nil {\n   217→\t\treturn\n   218→\t}\n   219→\n   220→\tvar agent agentStatus\n   221→\tif json.Unmarshal([]byte(statusJSON), &agent) != nil {\n   222→\t\treturn\n   223→\t}\n   224→\n   225→\tstatus.NeedsInput = agent.NeedsInput\n   226→\tstatus.Question = agent.Question\n   227→\tstatus.PRURL = agent.PRURL\n   228→\tif agent.Error != \"\" {\n   229→\t\tstatus.Error = agent.Error\n   230→\t}\n   231→}\n   232→"}]},"parent_tool_use_id":null,"session_id":"4aa0ce57-5476-4987-a635-a74810c9f869","uuid":"88f7a896-7804-4959-8346-bba105e33752","tool_use_result":{"type":"text","file":{"filePath":"/home/agent/workspace/internal/orchestrator/docker.go","content":"package orchestrator\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/aws/aws-sdk-go-v2/service/ssm\"\n\t\"github.com/rs/zerolog/log\"\n\n\t\"github.com/backflow-labs/backflow/internal/config\"\n\t\"github.com/backflow-labs/backflow/internal/models\"\n)\n\n// ContainerStatus represents the current state of an agent container.\ntype ContainerStatus struct {\n\tDone       bool\n\tExitCode   int\n\tNeedsInput bool\n\tQuestion   string\n\tError      string\n\tLogTail    string\n\tPRURL      string\n}\n\n// DockerManager manages agent containers on remote (SSM) or local hosts.\ntype DockerManager struct {\n\tconfig    *config.Config\n\tssmClient *ssm.Client\n}\n\n// NewDockerManager creates a new DockerManager.\nfunc NewDockerManager(cfg *config.Config) *DockerManager {\n\treturn &DockerManager{config: cfg}\n}\n\n// RunAgent starts a new agent container on the given instance for the task.\n// Returns the container ID on success.\nfunc (m *DockerManager) RunAgent(ctx context.Context, instance *models.Instance, task *models.Task) (string, error) {\n\tcmd := m.buildRunCommand(task)\n\n\toutput, err := m.runCommand(ctx, instance.InstanceID, cmd)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"run container: %w\", err)\n\t}\n\n\tcontainerID := strings.TrimSpace(output)\n\tif containerID == \"\" {\n\t\treturn \"\", fmt.Errorf(\"empty container ID returned\")\n\t}\n\tif !isHexString(containerID) {\n\t\treturn \"\", fmt.Errorf(\"docker run failed: %s\", containerID)\n\t}\n\n\tlog.Debug().Str(\"container\", containerID[:12]).Str(\"instance\", instance.InstanceID).Msg(\"started agent container\")\n\treturn containerID, nil\n}\n\n// InspectContainer checks a container's status and reads the agent's\n// status.json if the container has exited.\nfunc (m *DockerManager) InspectContainer(ctx context.Context, instanceID, containerID string) (ContainerStatus, error) {\n\tcmd := fmt.Sprintf(\n\t\t\"docker inspect --format '{{.State.Status}} {{.State.ExitCode}}' %s 2>/dev/null && docker logs --tail 20 %s 2>&1\",\n\t\tcontainerID, containerID,\n\t)\n\toutput, err := m.runCommand(ctx, instanceID, cmd)\n\tif err != nil {\n\t\treturn ContainerStatus{}, err\n\t}\n\n\tstatus, err := parseInspectOutput(output)\n\tif err != nil {\n\t\treturn ContainerStatus{}, err\n\t}\n\n\tif status.Done {\n\t\tm.enrichFromStatusJSON(ctx, instanceID, containerID, &status)\n\t}\n\n\treturn status, nil\n}\n\n// StopContainer stops and removes a container.\nfunc (m *DockerManager) StopContainer(ctx context.Context, instanceID, containerID string) error {\n\tcmd := fmt.Sprintf(\"docker stop -t 30 %s 2>/dev/null; docker rm %s 2>/dev/null\", containerID, containerID)\n\t_, err := m.runCommand(ctx, instanceID, cmd)\n\treturn err\n}\n\n// GetLogs retrieves the last N lines of a container's logs.\nfunc (m *DockerManager) GetLogs(ctx context.Context, instanceID, containerID string, tail int) (string, error) {\n\tcmd := fmt.Sprintf(\"docker logs --tail %d %s 2>&1\", tail, containerID)\n\treturn m.runCommand(ctx, instanceID, cmd)\n}\n\n// buildRunCommand constructs the full `docker run` command for an agent task.\nfunc (m *DockerManager) buildRunCommand(task *models.Task) string {\n\tenvFlags := m.buildEnvFlags(task)\n\tvolumeFlags := m.buildVolumeFlags()\n\n\treturn fmt.Sprintf(\n\t\t\"docker run -d --cpus=1 --memory=3g %s %s backflow-agent\",\n\t\tvolumeFlags,\n\t\tstrings.Join(envFlags, \" \"),\n\t)\n}\n\n// buildEnvFlags assembles the -e flags for the docker run command from the\n// task configuration and global config.\nfunc (m *DockerManager) buildEnvFlags(task *models.Task) []string {\n\tflags := []string{\n\t\tenvFlag(\"TASK_ID\", task.ID),\n\t\tenvFlag(\"REPO_URL\", shellEscape(task.RepoURL)),\n\t\tenvFlag(\"BRANCH\", shellEscape(task.Branch)),\n\t\tenvFlag(\"TARGET_BRANCH\", shellEscape(task.TargetBranch)),\n\t\tenvFlag(\"PROMPT\", shellEscape(task.Prompt)),\n\t\tenvFlag(\"MODEL\", shellEscape(task.Model)),\n\t\tenvFlag(\"EFFORT\", shellEscape(task.Effort)),\n\t\tfmt.Sprintf(\"-e MAX_BUDGET_USD=%g\", task.MaxBudgetUSD),\n\t\tfmt.Sprintf(\"-e MAX_TURNS=%d\", task.MaxTurns),\n\t\tfmt.Sprintf(\"-e CREATE_PR=%t\", task.CreatePR),\n\t\tfmt.Sprintf(\"-e SELF_REVIEW=%t\", task.SelfReview),\n\t\tenvFlag(\"AUTH_MODE\", string(m.config.AuthMode)),\n\t}\n\n\t// Optional task fields\n\tif task.PRTitle != \"\" {\n\t\tflags = append(flags, envFlag(\"PR_TITLE\", shellEscape(task.PRTitle)))\n\t}\n\tif task.PRBody != \"\" {\n\t\tflags = append(flags, envFlag(\"PR_BODY\", shellEscape(task.PRBody)))\n\t}\n\tif task.ClaudeMD != \"\" {\n\t\tflags = append(flags, envFlag(\"CLAUDE_MD\", shellEscape(task.ClaudeMD)))\n\t}\n\tif task.Context != \"\" {\n\t\tflags = append(flags, envFlag(\"TASK_CONTEXT\", shellEscape(task.Context)))\n\t}\n\n\t// Auth credentials\n\tif m.config.AuthMode == config.AuthModeAPIKey {\n\t\tflags = append(flags, envFlag(\"ANTHROPIC_API_KEY\", m.config.AnthropicAPIKey))\n\t}\n\tif m.config.GitHubToken != \"\" {\n\t\tflags = append(flags, envFlag(\"GITHUB_TOKEN\", m.config.GitHubToken))\n\t}\n\n\t// Custom env vars from the task\n\tfor k, v := range task.EnvVars {\n\t\tflags = append(flags, envFlag(k, shellEscape(v)))\n\t}\n\n\treturn flags\n}\n\n// buildVolumeFlags returns the -v flag for mounting Claude credentials when\n// using Max subscription auth, or an empty string otherwise.\nfunc (m *DockerManager) buildVolumeFlags() string {\n\tif m.config.AuthMode == config.AuthModeMaxSubscription && m.config.ClaudeCredentialsPath != \"\" {\n\t\treturn fmt.Sprintf(\"-v %s:/home/agent/.claude:ro\", m.config.ClaudeCredentialsPath)\n\t}\n\treturn \"\"\n}\n\n// envFlag returns a single \"-e KEY=VALUE\" flag string.\nfunc envFlag(key, value string) string {\n\treturn fmt.Sprintf(\"-e %s=%s\", key, value)\n}\n\n// agentStatus is the JSON structure written by the agent entrypoint to\n// /home/agent/workspace/status.json inside the container.\ntype agentStatus struct {\n\tNeedsInput bool   `json:\"needs_input\"`\n\tQuestion   string `json:\"question\"`\n\tComplete   bool   `json:\"complete\"`\n\tError      string `json:\"error\"`\n\tPRURL      string `json:\"pr_url\"`\n}\n\n// parseInspectOutput parses the combined output of `docker inspect` +\n// `docker logs` into a ContainerStatus.\nfunc parseInspectOutput(output string) (ContainerStatus, error) {\n\tlines := strings.SplitN(output, \"\\n\", 2)\n\tif len(lines) == 0 {\n\t\treturn ContainerStatus{}, fmt.Errorf(\"empty inspect output\")\n\t}\n\n\tparts := strings.Fields(lines[0])\n\tif len(parts) < 2 {\n\t\treturn ContainerStatus{}, fmt.Errorf(\"unexpected inspect format: %s\", lines[0])\n\t}\n\n\tstatus := ContainerStatus{}\n\tif len(lines) > 1 {\n\t\tstatus.LogTail = lines[1]\n\t}\n\n\tdockerState := parts[0]\n\tif dockerState == \"exited\" || dockerState == \"dead\" {\n\t\tstatus.Done = true\n\t\tfmt.Sscanf(parts[1], \"%d\", &status.ExitCode)\n\t\tif status.ExitCode != 0 {\n\t\t\tstatus.Error = fmt.Sprintf(\"container exited with code %d\", status.ExitCode)\n\t\t}\n\t}\n\n\treturn status, nil\n}\n\n// enrichFromStatusJSON reads the agent's status.json from the container and\n// merges its fields into the ContainerStatus.\nfunc (m *DockerManager) enrichFromStatusJSON(ctx context.Context, instanceID, containerID string, status *ContainerStatus) {\n\tcmd := fmt.Sprintf(\"docker cp %s:/home/agent/workspace/status.json /dev/stdout 2>/dev/null\", containerID)\n\tstatusJSON, err := m.runCommand(ctx, instanceID, cmd)\n\tif err != nil {\n\t\treturn\n\t}\n\n\tvar agent agentStatus\n\tif json.Unmarshal([]byte(statusJSON), &agent) != nil {\n\t\treturn\n\t}\n\n\tstatus.NeedsInput = agent.NeedsInput\n\tstatus.Question = agent.Question\n\tstatus.PRURL = agent.PRURL\n\tif agent.Error != \"\" {\n\t\tstatus.Error = agent.Error\n\t}\n}\n","numLines":232,"startLine":1,"totalLines":232}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014uNfL6a8RHvGFPs9KyMnMH","type":"tool_result","content":"     1→# Database Schema\n     2→\n     3→Backflow uses SQLite in WAL mode with foreign keys enabled. The schema is auto-migrated on startup via `internal/store/sqlite.go:migrate()` using `CREATE TABLE IF NOT EXISTS` statements.\n     4→\n     5→Connection string: `<path>?_journal_mode=WAL&_busy_timeout=5000&_foreign_keys=on`\n     6→\n     7→## Tables\n     8→\n     9→### `tasks`\n    10→\n    11→Stores Claude Code agent tasks submitted via the REST API.\n    12→\n    13→| Column | Type | Default | Description |\n    14→|--------|------|---------|-------------|\n    15→| `id` | `TEXT` | — | **Primary key.** ULID with `bf_` prefix (e.g. `bf_01KKQW82994E87Z99QVEMBN8V0`). |\n    16→| `status` | `TEXT` | `'pending'` | Task lifecycle state. One of: `pending`, `provisioning`, `running`, `completed`, `failed`, `interrupted`, `cancelled`. |\n    17→| `repo_url` | `TEXT` | — | Git repository URL to clone (required). |\n    18→| `branch` | `TEXT` | `''` | Branch to check out before running the agent. |\n    19→| `target_branch` | `TEXT` | `''` | Base branch for PR creation (e.g. `main`). |\n    20→| `prompt` | `TEXT` | — | The instruction given to Claude Code (required). |\n    21→| `context` | `TEXT` | `''` | Additional context appended to the prompt. |\n    22→| `model` | `TEXT` | `''` | Claude model override (e.g. `claude-sonnet-4-20250514`). |\n    23→| `effort` | `TEXT` | `''` | Agent effort level. One of: `low`, `medium`, `high`, `xhigh`, or empty for default. |\n    24→| `max_budget_usd` | `REAL` | `0` | Maximum spend in USD. 0 = unlimited. |\n    25→| `max_runtime_min` | `INTEGER` | `0` | Maximum wall-clock runtime in minutes. 0 = unlimited. |\n    26→| `max_turns` | `INTEGER` | `0` | Maximum agent conversation turns. 0 = unlimited. |\n    27→| `create_pr` | `INTEGER` | `0` | Boolean (0/1). Whether to create a pull request on completion. |\n    28→| `self_review` | `INTEGER` | `0` | Boolean (0/1). Whether the agent self-reviews before finishing. |\n    29→| `pr_title` | `TEXT` | `''` | Pull request title (if `create_pr` is set). |\n    30→| `pr_body` | `TEXT` | `''` | Pull request body/description. |\n    31→| `pr_url` | `TEXT` | `''` | URL of the created PR (populated after completion). |\n    32→| `allowed_tools` | `TEXT` | `'[]'` | JSON array of allowed Claude Code tool names. |\n    33→| `claude_md` | `TEXT` | `''` | Custom CLAUDE.md content injected into the agent container. |\n    34→| `env_vars` | `TEXT` | `'{}'` | JSON object of environment variables passed to the container. |\n    35→| `instance_id` | `TEXT` | `''` | EC2 instance ID where the container runs. |\n    36→| `container_id` | `TEXT` | `''` | Docker container ID on the assigned instance. |\n    37→| `retry_count` | `INTEGER` | `0` | Number of times this task has been re-queued (e.g. after spot interruption). |\n    38→| `cost_usd` | `REAL` | `0` | Tracked cost in USD. |\n    39→| `error` | `TEXT` | `''` | Error message if the task failed. |\n    40→| `created_at` | `TEXT` | — | RFC 3339 timestamp. When the task was created. |\n    41→| `updated_at` | `TEXT` | — | RFC 3339 timestamp. Last modification time. |\n    42→| `started_at` | `TEXT` | `NULL` | RFC 3339 timestamp. When the agent container started. Nullable. |\n    43→| `completed_at` | `TEXT` | `NULL` | RFC 3339 timestamp. When the task reached a terminal state. Nullable. |\n    44→\n    45→**Indexes:**\n    46→- `idx_tasks_status` on `status` — used by the orchestrator to find pending/running tasks.\n    47→- `idx_tasks_created` on `created_at` — used for ordered listing.\n    48→\n    49→### `instances`\n    50→\n    51→Tracks EC2 spot instances managed by the orchestrator.\n    52→\n    53→| Column | Type | Default | Description |\n    54→|--------|------|---------|-------------|\n    55→| `instance_id` | `TEXT` | — | **Primary key.** AWS EC2 instance ID (e.g. `i-0abc123def456`). |\n    56→| `instance_type` | `TEXT` | — | EC2 instance type (e.g. `c6g.2xlarge`). |\n    57→| `availability_zone` | `TEXT` | `''` | AWS AZ (e.g. `us-east-1a`). |\n    58→| `private_ip` | `TEXT` | `''` | Instance private IP address. |\n    59→| `status` | `TEXT` | `'pending'` | Instance lifecycle state. One of: `pending`, `running`, `draining`, `terminated`. |\n    60→| `max_containers` | `INTEGER` | `4` | Maximum concurrent agent containers on this instance. |\n    61→| `running_containers` | `INTEGER` | `0` | Current number of running containers. |\n    62→| `created_at` | `TEXT` | — | RFC 3339 timestamp. When the instance record was created. |\n    63→| `updated_at` | `TEXT` | — | RFC 3339 timestamp. Last modification time. |\n    64→\n    65→**Indexes:**\n    66→- `idx_instances_status` on `status` — used to find running/pending instances for task dispatch.\n    67→\n    68→## Status Lifecycles\n    69→\n    70→### Task statuses\n    71→\n    72→```\n    73→pending → provisioning → running → completed\n    74→                                  → failed\n    75→                                  → interrupted → (re-queued as pending)\n    76→         (any non-terminal)      → cancelled\n    77→```\n    78→\n    79→Terminal states: `completed`, `failed`, `cancelled`.\n    80→\n    81→### Instance statuses\n    82→\n    83→```\n    84→pending → running → draining → terminated\n    85→                  → terminated\n    86→```\n    87→\n    88→## Notes\n    89→\n    90→- All timestamps are stored as RFC 3339 strings, not SQLite datetime types.\n    91→- Booleans (`create_pr`, `self_review`) are stored as integers (0/1).\n    92→- JSON fields (`allowed_tools`, `env_vars`) are stored as serialized TEXT.\n    93→- Schema changes are applied idempotently in `migrate()` — new columns use `ALTER TABLE ... ADD COLUMN` with `IF NOT EXISTS` semantics.\n    94→"}]},"parent_tool_use_id":null,"session_id":"4aa0ce57-5476-4987-a635-a74810c9f869","uuid":"a75508fe-54a6-4a52-8a34-9daf41b06943","tool_use_result":{"type":"text","file":{"filePath":"/home/agent/workspace/docs/schema.md","content":"# Database Schema\n\nBackflow uses SQLite in WAL mode with foreign keys enabled. The schema is auto-migrated on startup via `internal/store/sqlite.go:migrate()` using `CREATE TABLE IF NOT EXISTS` statements.\n\nConnection string: `<path>?_journal_mode=WAL&_busy_timeout=5000&_foreign_keys=on`\n\n## Tables\n\n### `tasks`\n\nStores Claude Code agent tasks submitted via the REST API.\n\n| Column | Type | Default | Description |\n|--------|------|---------|-------------|\n| `id` | `TEXT` | — | **Primary key.** ULID with `bf_` prefix (e.g. `bf_01KKQW82994E87Z99QVEMBN8V0`). |\n| `status` | `TEXT` | `'pending'` | Task lifecycle state. One of: `pending`, `provisioning`, `running`, `completed`, `failed`, `interrupted`, `cancelled`. |\n| `repo_url` | `TEXT` | — | Git repository URL to clone (required). |\n| `branch` | `TEXT` | `''` | Branch to check out before running the agent. |\n| `target_branch` | `TEXT` | `''` | Base branch for PR creation (e.g. `main`). |\n| `prompt` | `TEXT` | — | The instruction given to Claude Code (required). |\n| `context` | `TEXT` | `''` | Additional context appended to the prompt. |\n| `model` | `TEXT` | `''` | Claude model override (e.g. `claude-sonnet-4-20250514`). |\n| `effort` | `TEXT` | `''` | Agent effort level. One of: `low`, `medium`, `high`, `xhigh`, or empty for default. |\n| `max_budget_usd` | `REAL` | `0` | Maximum spend in USD. 0 = unlimited. |\n| `max_runtime_min` | `INTEGER` | `0` | Maximum wall-clock runtime in minutes. 0 = unlimited. |\n| `max_turns` | `INTEGER` | `0` | Maximum agent conversation turns. 0 = unlimited. |\n| `create_pr` | `INTEGER` | `0` | Boolean (0/1). Whether to create a pull request on completion. |\n| `self_review` | `INTEGER` | `0` | Boolean (0/1). Whether the agent self-reviews before finishing. |\n| `pr_title` | `TEXT` | `''` | Pull request title (if `create_pr` is set). |\n| `pr_body` | `TEXT` | `''` | Pull request body/description. |\n| `pr_url` | `TEXT` | `''` | URL of the created PR (populated after completion). |\n| `allowed_tools` | `TEXT` | `'[]'` | JSON array of allowed Claude Code tool names. |\n| `claude_md` | `TEXT` | `''` | Custom CLAUDE.md content injected into the agent container. |\n| `env_vars` | `TEXT` | `'{}'` | JSON object of environment variables passed to the container. |\n| `instance_id` | `TEXT` | `''` | EC2 instance ID where the container runs. |\n| `container_id` | `TEXT` | `''` | Docker container ID on the assigned instance. |\n| `retry_count` | `INTEGER` | `0` | Number of times this task has been re-queued (e.g. after spot interruption). |\n| `cost_usd` | `REAL` | `0` | Tracked cost in USD. |\n| `error` | `TEXT` | `''` | Error message if the task failed. |\n| `created_at` | `TEXT` | — | RFC 3339 timestamp. When the task was created. |\n| `updated_at` | `TEXT` | — | RFC 3339 timestamp. Last modification time. |\n| `started_at` | `TEXT` | `NULL` | RFC 3339 timestamp. When the agent container started. Nullable. |\n| `completed_at` | `TEXT` | `NULL` | RFC 3339 timestamp. When the task reached a terminal state. Nullable. |\n\n**Indexes:**\n- `idx_tasks_status` on `status` — used by the orchestrator to find pending/running tasks.\n- `idx_tasks_created` on `created_at` — used for ordered listing.\n\n### `instances`\n\nTracks EC2 spot instances managed by the orchestrator.\n\n| Column | Type | Default | Description |\n|--------|------|---------|-------------|\n| `instance_id` | `TEXT` | — | **Primary key.** AWS EC2 instance ID (e.g. `i-0abc123def456`). |\n| `instance_type` | `TEXT` | — | EC2 instance type (e.g. `c6g.2xlarge`). |\n| `availability_zone` | `TEXT` | `''` | AWS AZ (e.g. `us-east-1a`). |\n| `private_ip` | `TEXT` | `''` | Instance private IP address. |\n| `status` | `TEXT` | `'pending'` | Instance lifecycle state. One of: `pending`, `running`, `draining`, `terminated`. |\n| `max_containers` | `INTEGER` | `4` | Maximum concurrent agent containers on this instance. |\n| `running_containers` | `INTEGER` | `0` | Current number of running containers. |\n| `created_at` | `TEXT` | — | RFC 3339 timestamp. When the instance record was created. |\n| `updated_at` | `TEXT` | — | RFC 3339 timestamp. Last modification time. |\n\n**Indexes:**\n- `idx_instances_status` on `status` — used to find running/pending instances for task dispatch.\n\n## Status Lifecycles\n\n### Task statuses\n\n```\npending → provisioning → running → completed\n                                  → failed\n                                  → interrupted → (re-queued as pending)\n         (any non-terminal)      → cancelled\n```\n\nTerminal states: `completed`, `failed`, `cancelled`.\n\n### Instance statuses\n\n```\npending → running → draining → terminated\n                  → terminated\n```\n\n## Notes\n\n- All timestamps are stored as RFC 3339 strings, not SQLite datetime types.\n- Booleans (`create_pr`, `self_review`) are stored as integers (0/1).\n- JSON fields (`allowed_tools`, `env_vars`) are stored as serialized TEXT.\n- Schema changes are applied idempotently in `migrate()` — new columns use `ALTER TABLE ... ADD COLUMN` with `IF NOT EXISTS` semantics.\n","numLines":94,"startLine":1,"totalLines":94}}}
