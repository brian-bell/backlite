# Backflow server configuration

# Mode: "ec2" (default, spot instances), "local" (Docker on local machine), or "fargate" (ECS tasks)
# BACKFLOW_MODE=ec2

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for codex harness
# OPENAI_API_KEY=sk-...

# GitHub personal access token (for cloning private repos and creating PRs)
GITHUB_TOKEN=ghp_...

# Server
BACKFLOW_LISTEN_ADDR=:8080
BACKFLOW_DATABASE_URL=postgresql://user:password@host:5432/backflow?sslmode=disable

# --- EC2 mode ---
AWS_REGION=us-east-1
BACKFLOW_INSTANCE_TYPE=m7g.xlarge
BACKFLOW_LAUNCH_TEMPLATE_ID=lt-...
BACKFLOW_MAX_INSTANCES=5
BACKFLOW_CONTAINERS_PER_INSTANCE=1

# --- Fargate mode ---
# BACKFLOW_ECS_CLUSTER=backflow
# BACKFLOW_ECS_TASK_DEFINITION=backflow-agent
# BACKFLOW_ECS_SUBNETS=subnet-abc123,subnet-def456
# BACKFLOW_CLOUDWATCH_LOG_GROUP=/ecs/backflow
# BACKFLOW_ECS_SECURITY_GROUPS=sg-abc123
# BACKFLOW_ECS_LAUNCH_TYPE=FARGATE_SPOT
# BACKFLOW_ECS_CONTAINER_NAME=backflow-agent
# BACKFLOW_ECS_LOG_STREAM_PREFIX=ecs
# BACKFLOW_ECS_ASSIGN_PUBLIC_IP=true
# BACKFLOW_MAX_CONCURRENT_TASKS=5
# Required when BACKFLOW_READER_IMAGE is set in Fargate mode
# BACKFLOW_ECS_READER_TASK_DEFINITION=backflow-reader

# S3 (task data: agent output, large prompt/context offload — optional, but required for Fargate with large prompts)
# BACKFLOW_S3_BUCKET=backflow-data-123456789012-us-east-1

# Agent image (default: backflow-agent; set to fake-agent for local blackbox/soak testing)
# BACKFLOW_AGENT_IMAGE=backflow-fake-agent

# Reader image (reading-mode tasks — /backflow read, task_mode=read)
# When BACKFLOW_READER_IMAGE is set, the following are required:
#   - BACKFLOW_DEFAULT_READ_MAX_BUDGET > 0
#   - BACKFLOW_DEFAULT_READ_MAX_RUNTIME_SEC > 0
#   - BACKFLOW_DEFAULT_READ_MAX_TURNS > 0
#   - SUPABASE_URL and SUPABASE_ANON_KEY (see Supabase section below)
#   - OPENAI_API_KEY (for the orchestrator's embeddings client)
#   - BACKFLOW_ECS_READER_TASK_DEFINITION (Fargate mode only)
# BACKFLOW_READER_IMAGE=backflow-reader
# BACKFLOW_DEFAULT_READ_MAX_BUDGET=0.5
# BACKFLOW_DEFAULT_READ_MAX_RUNTIME_SEC=300
# BACKFLOW_DEFAULT_READ_MAX_TURNS=20

# Container resources
BACKFLOW_CONTAINER_CPUS=2
BACKFLOW_CONTAINER_MEMORY_GB=8

# Agent defaults
# BACKFLOW_DEFAULT_HARNESS=claude_code
BACKFLOW_DEFAULT_EFFORT=medium
BACKFLOW_DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6
BACKFLOW_DEFAULT_CODEX_MODEL=gpt-5.4
BACKFLOW_DEFAULT_MAX_BUDGET=10
BACKFLOW_DEFAULT_MAX_RUNTIME_SEC=1800
BACKFLOW_DEFAULT_MAX_TURNS=200
BACKFLOW_DEFAULT_CREATE_PR=true
BACKFLOW_DEFAULT_SELF_REVIEW=false
BACKFLOW_DEFAULT_SAVE_AGENT_OUTPUT=true

# Webhooks (optional)
# BACKFLOW_WEBHOOK_URL=https://hooks.slack.com/services/...
# BACKFLOW_WEBHOOK_EVENTS=task.needs_input,task.failed,task.completed

# Retry
# BACKFLOW_MAX_USER_RETRIES=2

# Supabase (reading mode — reader agent image)
# Project URL, e.g. https://<ref>.supabase.co
# SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_...) — Dashboard → Project Settings → API Keys
# Passes the gateway and authenticates as the anon Postgres role (read-only).
# SUPABASE_ANON_KEY=sb_publishable_...

# Orchestrator
BACKFLOW_POLL_INTERVAL_SEC=5
