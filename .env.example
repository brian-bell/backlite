# Backflow server configuration

# Auth mode: "api_key" (multi-agent) or "max_subscription" (serial, one at a time)
BACKFLOW_AUTH_MODE=api_key

# Required for api_key mode
ANTHROPIC_API_KEY=sk-ant-...

# Required for max_subscription mode (path to ~/.claude/ with cached OAuth credentials)
# CLAUDE_CREDENTIALS_PATH=/home/you/.claude

# GitHub personal access token (for cloning private repos and creating PRs)
GITHUB_TOKEN=ghp_...

# Server
BACKFLOW_LISTEN_ADDR=:8080
BACKFLOW_DB_PATH=backflow.db

# AWS
AWS_REGION=us-east-1
BACKFLOW_INSTANCE_TYPE=m7g.xlarge
BACKFLOW_LAUNCH_TEMPLATE_ID=lt-...
BACKFLOW_MAX_INSTANCES=5
BACKFLOW_CONTAINERS_PER_INSTANCE=1

# Container resources
BACKFLOW_CONTAINER_CPUS=2
BACKFLOW_CONTAINER_MEMORY_GB=8

# Agent defaults
BACKFLOW_DEFAULT_MODEL=claude-sonnet-4-6
BACKFLOW_DEFAULT_MAX_BUDGET=10
BACKFLOW_DEFAULT_MAX_RUNTIME_MIN=30
BACKFLOW_DEFAULT_MAX_TURNS=200

# Webhooks (optional)
# BACKFLOW_WEBHOOK_URL=https://hooks.slack.com/services/...
# BACKFLOW_WEBHOOK_EVENTS=task.needs_input,task.failed,task.completed

# Orchestrator
BACKFLOW_POLL_INTERVAL_SEC=5
